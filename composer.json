{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "awcodes/filament-curator": "^5.0",
        "awcodes/mason": "^3.0",
        "blade-ui-kit/blade-icons": "^1.9",
        "blendbyte/filament-resource-lock": "^2.0",
        "codewithdennis/filament-select-tree": "4.x",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "mipress/core": "@dev",
        "mipress/forms": "@dev",
        "mipress/social-feeds": "@dev",
        "spatie/laravel-permission": "^7.2",
        "spatie/laravel-sluggable": "^3.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.1",
        "laravel/boost": "*",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "@install:web"
        ],
        "install:web": [
            "@php scripts/install-web.php"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:smoke": [
            "@php artisan test --compact --filter=ProductionSmokeTest"
        ],
        "test:ci": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan test --compact"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "github-protocols": [
            "https"
        ],
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/mipress/core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/mipress/forms",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/mipress/social-feeds",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
